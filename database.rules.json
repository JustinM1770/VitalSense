{
  "rules": {
    ".read": false,
    ".write": false,

    "emergency_tokens": {
      "$tokenId": {
        ".read": "data.exists() && data.child('active').val() === true && data.child('expiresAt').val() > now",
        ".write": "auth != null"
      }
    },

    "alerts": {
      "$uid": {
        "$sosId": {
          ".read": "data.exists() && (data.child('status').val() == 'active' || data.child('status').val() == 'accepted')",
          ".write": "auth != null && (auth.uid == $uid || (newData.child('type').val() == 'SOS' && newData.child('source').val() == 'wear_internet'))"
        },
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && (auth.uid == $uid || newData.child('type').val() == 'SOS')"
      }
    },

    "vitals": {
      "current": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null"
        }
      }
    },

    "patients": {
      "pairing_codes": {
        "$code": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      },

      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",

        "watch": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        },

        "heartRate": { ".read": true },
        "spo2": { ".read": true },
        "glucose": { ".read": true },
        "timestamp": { ".read": true },

        "profile": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid",

          "nombre": { ".read": true },
          "apellidos": { ".read": true },
          "nacimiento": { ".read": true },
          "fechaNacimiento": { ".read": true },
          "genero": { ".read": true },
          "tipoSangre": { ".read": true },
          "alergias": { ".read": true },
          "padecimientos": { ".read": true },
          "medicamentos": { ".read": true },
          "contactoEmergencia": { ".read": true },
          "telefonoEmergencia": { ".read": true }
        }
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        
        "datosMedicos": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid",

          "nombre": { ".read": true },
          "apellidos": { ".read": true },
          "nacimiento": { ".read": true },
          "fechaNacimiento": { ".read": true },
          "genero": { ".read": true },
          "tipoSangre": { ".read": true },
          "alergias": { ".read": true },
          "padecimientos": { ".read": true },
          "medicamentos": { ".read": true },
          "contactoEmergencia": { ".read": true },
          "telefonoEmergencia": { ".read": true }
        }
      }
    }
  }
}